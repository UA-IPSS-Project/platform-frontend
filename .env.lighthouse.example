# ─── Lighthouse Audit Credentials ───────────────────────────────────────────
# Copy this file to .env.lighthouse and fill in the values.
# .env.lighthouse is gitignored and must never be committed.

# Base URL of the running dev server.
BASE_URL=http://localhost:5173

# UTENTE — regular user, logs in with NIF (9-digit number).
UTENTE_NIF=
UTENTE_PASSWORD=

# SECRETARIA — staff role, logs in with institutional email.
SECRETARIA_EMAIL=
SECRETARIA_PASSWORD=

# ADMIN — administrator role, logs in with institutional email.
ADMIN_EMAIL=
ADMIN_PASSWORD=
