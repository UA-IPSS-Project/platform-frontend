    },
    "sections": [
      {
        "title": "Data Controller Identification",
        "paragraphs": [
          "This Privacy Policy governs the processing of personal data carried out by IPSS Florinhas do Vouga, legal entity no. 501156577, headquartered at Praceta Florinhas do Vouga, no. 10, 3810-064 Aveiro.",
          "Contacts: Phone +351 234 377 330 | Email secretaria@florinhasdovouga.pt",
          "The Institution is a diocesan non-profit social institution (IPSS), acting within its social and community mission."
        ]
      },
      {
        "title": "Commitment to Data Protection",
        "paragraphs": [
          "IPSS Florinhas do Vouga is committed to protecting the personal data of its users, beneficiaries, volunteers, patrons, donors, benefactors, collaborators, partners, and other entities interacting with it.",
          "Personal data processing is carried out in compliance with the General Data Protection Regulation (GDPR) and applicable national legislation, ensuring lawfulness, fairness, transparency, minimization, accuracy, integrity, and confidentiality."
        ]
      },
      {
        "title": "Personal Data Collected",
        "paragraphs": [
          "The following data may be collected, among others:",
          "Data is collected only when necessary and under an appropriate legal basis."
        ],
        "bullets": [
          "Name",
          "Tax identification number",
          "Phone contacts",
          "Email address",
          "Address",
          "Data required for receipt issuance",
          "Data voluntarily provided through forms"
        ]
      },
      {
        "title": "Purpose of Data Processing",
        "paragraphs": [
          "Personal data is processed for the following purposes:",
          "Data will not be used for purposes incompatible with those that justified its collection."
        ],
        "bullets": [
          "Administrative and institutional management",
          "Donation processing",
          "Institutional communication",
          "Volunteer management",
          "Compliance with legal obligations",
          "Response to contact requests"
        ]
      },
      {
        "title": "Data Retention",
        "paragraphs": [
          "Personal data will be retained only for the period necessary to fulfill the purposes that determined its collection or for the period required by legal obligations."
        ]
      },
      {
        "title": "Data Subject Rights",
        "paragraphs": [
          "Under the law, data subjects may exercise the following rights:",
          "These rights can be exercised via email at secretaria@florinhasdovouga.pt",
          "If you believe your rights were not respected, you may lodge a complaint with the Portuguese Data Protection Authority (CNPD)."
        ],
        "bullets": [
          "Right of access",
          "Right to rectification",
          "Right to erasure",
          "Right to restriction of processing",
          "Right to object",
          "Right to data portability, where applicable"
        ]
      },
      {
        "title": "What Cookies Are",
        "paragraphs": [
          "Cookies are small text files stored on the user's device when visiting a website, helping improve browsing experience."
        ]
      },
      {
        "title": "Types of Cookies Used",
        "paragraphs": [
          "The website may use:",
          "No invasive commercial-purpose cookies are used."
        ],
        "bullets": [
          "Strictly necessary cookies for site operation",
          "Performance and statistical analysis cookies (when applicable)",
          "Functionality cookies"
        ]
      },
      {
        "title": "Cookie Management",
        "paragraphs": [
          "Users may configure their browser at any time to block or delete cookies.",
          "Disabling certain cookies may affect website functionality."
        ]
      },
      {
        "title": "Policy Changes",
        "paragraphs": [
          "IPSS Florinhas do Vouga reserves the right to update this Policy whenever necessary, and changes will be published on the website."
        ]
      }
    ]
  },
